generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  role        String   @default("TENANT") // TENANT, OWNER, ADMIN
  avatar      String?
  gender      String?  // MALE, FEMALE, OTHER
  isVerified  Boolean  @default(false)
  kycDoc      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownedPGs      PG[]
  bookings      Booking[]
  payments      Payment[]
  complaints    Complaint[]
  tenants       Tenant[]
  activityLogs  ActivityLog[]
}

model PG {
  id          String   @id @default(cuid())
  name        String
  ownerId     String
  description String?
  address     String
  city        String   @default("Bangalore")
  lat         Float?
  lng         Float?
  gender      String   @default("UNISEX") // MALE, FEMALE, UNISEX
  price       Float    // monthly rent
  securityDeposit Float @default(0)
  amenities   String   @default("") // comma-separated: wifi,ac,food,laundry
  images      String   @default("")
  rating      Float    @default(4.0)
  totalReviews Int     @default(0)
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner      User      @relation(fields: [ownerId], references: [id])
  rooms      Room[]
  bookings   Booking[]
  payments   Payment[]
  complaints Complaint[]
  tenants    Tenant[]

  @@index([ownerId])
  @@index([city])
  @@index([gender])
  @@index([status])
}

model Room {
  id        String   @id @default(cuid())
  pgId      String
  roomCode  String
  roomType  String   @default("SHARED") // SINGLE, DOUBLE, TRIPLE, DORMITORY
  floor     Int      @default(1)
  hasAC     Boolean  @default(false)
  hasAttachedBath Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pg   PG    @relation(fields: [pgId], references: [id], onDelete: Cascade)
  beds Bed[]
  tenants Tenant[]

  @@index([pgId])
}

model Bed {
  id        String   @id @default(cuid())
  roomId    String
  bedNumber Int
  status    String   @default("AVAILABLE") // AVAILABLE, OCCUPIED, MAINTENANCE
  price     Float?   // override room/PG price if different
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  room     Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  bookings Booking[]
  tenants  Tenant[]

  @@index([roomId])
  @@index([status])
}

model Booking {
  id          String   @id @default(cuid())
  userId      String
  pgId        String
  bedId       String
  checkInDate DateTime
  status      String   @default("PENDING") // PENDING, CONFIRMED, ACTIVE, COMPLETED, CANCELLED
  advancePaid Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])
  pg         PG       @relation(fields: [pgId], references: [id])
  bed        Bed      @relation(fields: [bedId], references: [id])
  payments   Payment[]

  @@index([userId])
  @@index([pgId])
  @@index([bedId])
  @@index([status])
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  pgId        String
  bookingId   String?
  amount      Float
  type        String   @default("RENT") // RENT, ADVANCE, SECURITY_DEPOSIT
  status      String   @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  dueDate     DateTime?
  paidDate    DateTime?
  method      String?  // UPI, CARD, NET_BANKING, CASH
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  pg      PG       @relation(fields: [pgId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([userId])
  @@index([pgId])
  @@index([status])
}

model Complaint {
  id          String   @id @default(cuid())
  userId      String
  pgId        String
  title       String
  description String?
  category    String   @default("GENERAL") // MAINTENANCE, CLEANLINESS, NOISE, SAFETY, GENERAL
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  assignedTo  String?
  resolution  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  pg   PG   @relation(fields: [pgId], references: [id])

  @@index([userId])
  @@index([pgId])
  @@index([status])
}

model Vendor {
  id        String   @id @default(cuid())
  name      String
  type      String   // PLUMBER, ELECTRICIAN, CLEANER, PAINTER, CARPENTER, WIFI, GENERAL
  phone     String
  email     String?
  city      String   @default("Bangalore")
  area      String?
  rating    Float    @default(4.0)
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([city])
}

model Worker {
  id        String   @id @default(cuid())
  name      String
  role      String   // SECURITY, CLEANER, COOK, MANAGER, MAINTENANCE
  phone     String
  pgId      String?
  shift     String?  // MORNING, EVENING, NIGHT
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pgId])
  @@index([role])
}

// Owner-managed tenant (directly added by owner, no user account required)
model Tenant {
  id          String   @id @default(cuid())
  ownerId     String
  pgId        String
  roomId      String
  bedId       String
  name        String
  phone       String
  email       String?
  aadhaar     String?
  gender      String?
  rentAmount  Float    @default(0)
  rentDueDay  Int      @default(5) // day of month rent is due (1-28)
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE, EVICTED
  notes       String?
  joinedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User     @relation(fields: [ownerId], references: [id])
  pg          PG       @relation(fields: [pgId], references: [id])
  room        Room     @relation(fields: [roomId], references: [id])
  bed         Bed      @relation(fields: [bedId], references: [id])
  rentRecords RentRecord[]

  @@index([ownerId])
  @@index([pgId])
  @@index([roomId])
  @@index([bedId])
  @@index([status])
}

// Rent records for owner-managed tenants
model RentRecord {
  id          String   @id @default(cuid())
  tenantId    String
  month       String   // "2025-01"
  amount      Float
  status      String   @default("PENDING") // PENDING, PAID, OVERDUE, PARTIAL
  paidDate    DateTime?
  method      String?  // CASH, UPI, CARD, NET_BANKING
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([month])
  @@index([status])
}

// Activity log for owner dashboard
model ActivityLog {
  id          String   @id @default(cuid())
  ownerId     String
  action      String   // TENANT_ADDED, BED_UPDATED, PAYMENT_COLLECTED, etc.
  description String?
  metadata    String?  // JSON string for extra data
  createdAt   DateTime @default(now())

  owner       User     @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([createdAt])
}
